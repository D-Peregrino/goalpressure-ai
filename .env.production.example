# GoalPressure AI — production environment template
# Copy to your host secrets manager (Railway / Vercel). Never commit real values.

NODE_ENV=production

# ─── Sportmonks (live feed) ─────────────────────────────────────────────────
SPORTMONKS_API_TOKEN=
# SPORTMONKS_API_BASE_URL=https://api.sportmonks.com/v3/football
# SPORTMONKS_FETCH_TIMEOUT_MS=15000

# ─── Supabase (hybrid cloud persistence) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Telegram (keep sandbox until ops approval) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SANDBOX_MODE=true

# ─── Logging ────────────────────────────────────────────────────────────────
# Set true only for short-lived debugging in production
GP_LOG_VERBOSE=false

# ─── Host (Railway sets PORT automatically) ───────────────────────────────────
PORT=3000
