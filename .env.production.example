# GoalPressure AI — production environment template
# Copy to your host secrets manager (Railway / Vercel). Never commit real values.

NODE_ENV=production

# ─── App URL (checkout, redirects, webhooks) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# ─── Sportmonks (live feed) ─────────────────────────────────────────────────
SPORTMONKS_API_TOKEN=
# SPORTMONKS_API_BASE_URL=https://api.sportmonks.com/v3/football
# SPORTMONKS_FETCH_TIMEOUT_MS=15000

# ─── Supabase (auth + dados comerciais + runtime) ─────────────────────────────
# Servidor: use SUPABASE_URL + SERVICE_ROLE_KEY (nunca expor service role no client)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Cliente (auth no browser) — obrigatório em produção para login real
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dica: pode definir só NEXT_PUBLIC_SUPABASE_URL; o servidor reutiliza se SUPABASE_URL estiver vazio.

# ─── Admin comercial ─────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@seudominio.com

# ─── Pagamentos (opcional — sem chave = checkout mock) ─────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# ─── E-mail transacional ─────────────────────────────────────────────────────
EMAIL_PROVIDER=log
# RESEND_API_KEY=

# ─── Telegram (keep sandbox until ops approval) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# false = real send via api.telegram.org/bot<TOKEN>/sendMessage
TELEGRAM_SANDBOX_MODE=false

# ─── Logging ────────────────────────────────────────────────────────────────
# Set true only for short-lived debugging in production
GP_LOG_VERBOSE=false

# ─── Live runtime (Railway 24/7) ──────────────────────────────────────────────
GP_AUTO_START_RUNTIME=true
GP_POLLING_INTERVAL_MS=15000
GP_INTERNAL_BASE_URL=https://your-app.up.railway.app

# ─── Host (Railway sets PORT automatically) ───────────────────────────────────
PORT=3000
