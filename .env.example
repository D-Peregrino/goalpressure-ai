# Sportmonks Football API (server-side only — never expose in client code)
SPORTMONKS_API_TOKEN=your_token_here
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football

# Seed/mock ao vivo — SOMENTE dev sem token (produção: false)
GP_SEED_LIVE=false
GP_ALLOW_SEED=false

# Optional overrides
# SPORTMONKS_API_BASE_URL=https://api.sportmonks.com/v3/football
# SPORTMONKS_FETCH_TIMEOUT_MS=15000
# API Usage Monitor — monthly call quota for your SportMonks plan
# SPORTMONKS_MONTHLY_QUOTA=3000
# SPORTMONKS_PLAN_NAME=Growth
# SPORTMONKS_PREMIUM_MODE=true
# Growth inplay includes (v5): statistics, trends (momentum), xGFixture, comments, timeline, inplayOdds, premiumOdds
# SPORTMONKS_ODDS_PREMIUM=true
# SPORTMONKS_FORCE_INCLUDE_REDISCOVER=true

# SaaS tiers (client demo — replace with Supabase/Stripe)
# NEXT_PUBLIC_DEFAULT_TIER=free

# Telegram Signal Engine (server-side only — keep sandbox until ops approval)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Destinos gerenciados em /admin/telegram (telegram_destinations). CHAT_ID abaixo = fallback legado.
TELEGRAM_CHAT_ID=your_chat_id_here
# When true, messages are logged only — never sent to Telegram API
TELEGRAM_SANDBOX_MODE=true

# Supabase Auth (obrigatório em produção)
NEXT_PUBLIC_SUPABASE_URL=
# Use ANON_KEY ou PUBLISHABLE_KEY (Railway) — mesma chave pública do projeto
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Servidor (dados + admin; opcional se só auth público)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (checkout redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (e-mails separados por vírgula)
ADMIN_EMAILS=seu@email.com

# Pagamentos Stripe (recomendado em produção)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COUPON_BARBOSATIPS75=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_FOUNDER_MONTHLY=
STRIPE_PRICE_FOUNDER_YEARLY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_FAILURE_URL=
MERCADOPAGO_PENDING_URL=

# E-mail transacional (log | resend | sendgrid)
EMAIL_PROVIDER=log

# GoalPressure Signal Exchange (rede operacional contextual)
NETWORK_ENGINE_ENABLED=true
NETWORK_ENGINE_SANDBOX=true

# Live OPS Center (/ops)
OPS_CENTER_ENABLED=true
OPS_CENTER_SANDBOX=true

# Command System (⌘K / Ctrl+K)
NEXT_PUBLIC_COMMAND_ENABLED=true
COMMAND_ENABLED=true
