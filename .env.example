# Sportmonks Football API (server-side only — never expose in client code)
SPORTMONKS_API_TOKEN=your_token_here

# Optional overrides
# SPORTMONKS_API_BASE_URL=https://api.sportmonks.com/v3/football
# SPORTMONKS_FETCH_TIMEOUT_MS=15000
# API Usage Monitor — monthly call quota for your SportMonks plan
# SPORTMONKS_MONTHLY_QUOTA=3000
# SPORTMONKS_PLAN_NAME=Growth
# SPORTMONKS_PREMIUM_MODE=true
# SPORTMONKS_ODDS_PREMIUM=true
# SPORTMONKS_FORCE_INCLUDE_REDISCOVER=true

# SaaS tiers (client demo — replace with Supabase/Stripe)
# NEXT_PUBLIC_DEFAULT_TIER=free

# Telegram Signal Engine (server-side only — keep sandbox until ops approval)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# When true, messages are logged only — never sent to Telegram API
TELEGRAM_SANDBOX_MODE=true

# Supabase (server-side only — service role, never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
